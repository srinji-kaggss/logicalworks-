#!/usr/bin/env python3
"""
lgwks - local Logical Works agentic framework entrypoint.
Consolidated 10-verb surface following dogfood audit #218.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path
from typing import Any

import lgwks_sqlite

ROOT = Path(__file__).resolve().parent

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="lgwks")
    parser.add_argument("--machine", action="store_true",
                        help="machine-first output: pure JSON/ND-JSON, no decoration, no escape codes, no prompts")
    parser.add_argument("--transform", help="transform machine output using a simple path expression (Issue 159)")
    parser.add_argument("-r", "--raw", action="store_true",
                        help="output raw scalar strings when using --transform (Issue 159)")
    
    sub = parser.add_subparsers(dest="command", required=False)

    # ── CANONICAL AGENT VERBS (The 10 Verbs) ───────────────────────────────
    
    # 1. research — unified orchestrator (akinator, begin, probe, project)
    import lgwks_research; lgwks_research.add_parser(sub)
    
    # 2. crawl — unified crawler (fetch, jarvis, substrate, pipeline)
    import lgwks_crawl; lgwks_crawl.add_parser(sub)
    
    # 3. review — graph-aware code/security review (review, do code, ship)
    import lgwks_review; lgwks_review.add_parser(sub)
    
    # 4. repo — lifecycle and forensics (audit, handoff, graph, solve)
    import lgwks_repo; lgwks_repo.add_parser(sub)
    
    # 5. graph — mathematical/structural graph queries (rank, score, viz, codebase)
    import lgwks_graph; lgwks_graph.add_graph_parser(sub)
    
    # 6. route — intent routing and refinement (map, engine, route)
    import lgwks_route; lgwks_route.add_parser(sub)
    
    # 7. gate — safety and governance (aup, cohere, admission, access)
    import lgwks_gate; lgwks_gate.add_parser(sub)
    
    # 8. state — durable state and context (run, context, spawn, crdt)
    t6 = sub.add_parser("state", help="T6: durable state and context fabric")
    t6_sub = t6.add_subparsers(dest="state_cmd", required=True)
    import lgwks_run; lgwks_run.add_parser(t6_sub)
    import lgwks_context; lgwks_context.add_parser(t6_sub)
    import lgwks_spawn; lgwks_spawn.add_parser(t6_sub)
    import lgwks_crdt; lgwks_crdt.add_parser(t6_sub)
    import lgwks_cortex; lgwks_cortex.add_parser(t6_sub)

    # 9. ops — system operations and fleet management (daemon, batch, doctor)
    ops = sub.add_parser("ops", help="system operations and management")
    ops_sub = ops.add_subparsers(dest="ops_cmd", required=True)
    import lgwks_daemon; lgwks_daemon.add_parser(ops_sub)
    import lgwks_batch; lgwks_batch.add_parser(ops_sub)
    import lgwks_agent_os; lgwks_agent_os.add_parser(ops_sub)
    import lgwks_workflows; lgwks_workflows.add_parser(ops_sub)

    # doctor — top-level pre-flight shortcut required by the repo contract
    doctor = sub.add_parser("doctor", help="shortcut: report local capability and daemon health")
    doctor.set_defaults(func=_doctor_dispatch)

    # Backward-compatible public commands documented in README.md.
    # NOTE: the run/context/agent-os top-level aliases were collapsed into their
    # canonical grouped forms (state run, state context, ops agent-os). Legacy
    # callers are still served by _apply_deprecation_shim (warn + rewrite); the
    # surface is held by the verb-budget gate in tests/test_cli_contract.py.
    import lgwks_model_hub; lgwks_model_hub.add_parser(sub)
    import lgwks_jarvis; lgwks_jarvis.add_parser(sub)
    import lgwks_manifest; lgwks_manifest.add_parser(sub)
    import lgwks_files; lgwks_files.add_parser(sub)
    auth = sub.add_parser("auth", add_help=False, help="compat: capability auth vault")
    auth.add_argument("-h", "--help", dest="auth_help", action="store_true")
    auth.add_argument("auth_args", nargs=argparse.REMAINDER)
    auth.set_defaults(func=_auth_dispatch)
    fetch = sub.add_parser("fetch", help="compat: render and extract one page in a browser")
    fetch.add_argument("url")
    fetch.add_argument("--max-chars", type=int, default=8000)
    fetch.add_argument("--json", action="store_true")
    fetch.add_argument("--chromium", action="store_true", help="use chromium instead of webkit")
    fetch.add_argument("--no-session", action="store_true", help="do not use saved browser session")
    fetch.set_defaults(func=_fetch_dispatch)
    
    # 11. verify — deterministic CI / Keel integration
    import lgwks_verify; lgwks_verify.add_parser(sub)

    # 10. human — interactive/setup verbs (login, tui, repl, init)
    hum = sub.add_parser("human", help="interactive and human-only verbs")
    hum_sub = hum.add_subparsers(dest="human_command", required=True)
    import lgwks_browser; # for login
    login = hum_sub.add_parser("login", help="save browser session")
    login.add_argument("target")
    login.set_defaults(func=_login_dispatch)
    hum_sub.add_parser("tui", help="launch Rust TUI").set_defaults(func=_tui_dispatch)
    repl = hum_sub.add_parser("repl", help="interactive readline")
    repl.add_argument("--repo", default=".")
    repl.set_defaults(func=_repl_dispatch)
    hum_sub.add_parser("initialize", help="first-time setup").set_defaults(func=_initialize_dispatch)

    # ── AGENT SHORTCUTS ─────────────────────────────────────────────────────
    # begin/probe were removed: both were thin aliases that just called
    # research_command (probe's "subconscious engine" help was false — it ran
    # research). Use `research <prompt>` / `research <prompt> --json`, or the
    # single agentic front door `route act <intent>`.

    # solve — deterministic git-worry prover (diagnose → relate → narrate)
    import lgwks_solve; lgwks_solve.add_parser(sub)

    # do — conversational orchestrator
    import lgwks_do; lgwks_do.add_parser(sub)

    # wf-run — workflow DSL
    import lgwks_dsl; lgwks_dsl.add_parser(sub)

    # x — multiply intent
    mult = sub.add_parser("x", help="shortcut: multiply intent command chain")
    mult.add_argument("expr")
    mult.add_argument("--yes", action="store_true")
    mult.set_defaults(func=_multiply_dispatch)

    return parser


def _multiply_dispatch(args) -> int:
    import lgwks_multiply
    return lgwks_multiply.multiply_command(args)

def _login_dispatch(args) -> int:
    import lgwks_browser
    return lgwks_browser.login_command(args)

def _tui_dispatch(args) -> int:
    import subprocess
    root = Path(__file__).resolve().parent
    binary = root / "tui" / "target" / "release" / "lgwks-tui"
    if not binary.exists(): binary = root / "tui" / "target" / "debug" / "lgwks-tui"
    if not binary.exists(): return 1
    return subprocess.call([str(binary), "--repo", str(root)])

def _repl_dispatch(args) -> int:
    import lgwks_repl
    return lgwks_repl.run_repl(repo_path=getattr(args, "repo", "."))

def _initialize_dispatch(args) -> int:
    import lgwks_agent_os
    return lgwks_agent_os.initialize_command(args)

def _doctor_dispatch(args) -> int:
    import lgwks_capabilities
    import lgwks_daemon

    capability_checks = lgwks_capabilities.doctor()
    daemon_report = lgwks_daemon.SessionDaemon(ROOT).doctor()
    report = {
        "schema": "lgwks.doctor.v1",
        "ok": bool(daemon_report.get("ok")),
        "capabilities": capability_checks,
        "daemon": daemon_report,
    }
    print(json.dumps(report, indent=2, sort_keys=True))
    return 0 if report["ok"] else 1

def _auth_dispatch(args) -> int:
    import subprocess
    argv = list(getattr(args, "auth_args", []) or ["--help"])
    if getattr(args, "auth_help", False):
        argv = ["--help"]
    return subprocess.call([sys.executable, str(ROOT / "tools" / "lgwks-auth"), *argv])

def _fetch_dispatch(args) -> int:
    import lgwks_browser
    result = lgwks_browser.render(
        args.url,
        max_chars=args.max_chars,
        use_session=not getattr(args, "no_session", False),
        browser_engine="chromium" if getattr(args, "chromium", False) else "webkit",
    )
    if getattr(args, "json", False) or os.environ.get("LGWRS_MACHINE") == "1":
        print(json.dumps(result, indent=2, sort_keys=True))
    elif result.get("ok"):
        print(result.get("text", ""))
    else:
        print(result.get("reason", "fetch failed"), file=sys.stderr)
    return 0 if result.get("ok") else 1

class TransformStdout:
    """Buffer stdout and apply a path expression (Issue 159) on close."""
    def __init__(self, expr: str, raw: bool):
        self.expr = expr
        self.raw = raw
        self.buffer = ""
        self.original_stdout = sys.stdout

    def write(self, s):
        self.buffer += s

    def flush(self):
        pass

    def close(self):
        if not self.buffer.strip():
            return
        import lgwks_transform
        results = []
        try:
            data = json.loads(self.buffer)
            results.append(lgwks_transform.apply_transform(data, self.expr))
        except json.JSONDecodeError:
            for line in self.buffer.strip().splitlines():
                if not line.strip():
                    continue
                try:
                    results.append(lgwks_transform.apply_transform(json.loads(line), self.expr))
                except json.JSONDecodeError:
                    pass
        for res in results:
            if res is None:
                continue
            if self.raw and isinstance(res, str):
                self.original_stdout.write(res + "\n")
            elif self.raw and isinstance(res, list) and all(isinstance(x, str) for x in res):
                for x in res:
                    self.original_stdout.write(x + "\n")
            else:
                self.original_stdout.write(json.dumps(res, indent=2 if len(results) == 1 else None) + "\n")
        self.original_stdout.flush()


# Legacy top-level verb -> canonical grouped path. These aliases were kept
# "temporarily" while the grouped surface was built; collapsing them removes
# duplicate intent labels from the cortex training stream (semantic exclusivity).
_DEPRECATED_VERBS = {
    "run": ["state", "run"],
    "context": ["state", "context"],
    "agent-os": ["ops", "agent-os"],
}


def _apply_deprecation_shim(argv: list[str]) -> list[str]:
    """Rewrite a legacy top-level verb to its canonical grouped path.

    Warns once on stderr so callers migrate, then delegates. Pure read; only
    rewrites when the legacy verb is the leading token (never mid-command)."""
    if not argv:
        return argv
    target = _DEPRECATED_VERBS.get(argv[0])
    if target is None:
        return argv
    sys.stderr.write(
        f"[lgwks] deprecated: 'lgwks {argv[0]}' -> use 'lgwks {' '.join(target)}'\n"
    )
    return target + argv[1:]


def main(argv: list[str] | None = None) -> int:
    if argv is None:
        argv = sys.argv[1:]
    argv = _apply_deprecation_shim(argv)
    parser = build_parser()
    args, unknown = parser.parse_known_args(argv)
    if unknown: parser.error(f"unrecognized arguments: {' '.join(unknown)}")
    if not hasattr(args, "func"):
        parser.print_help()
        return 0
    # Global --machine propagates to subcommands via env (modules suppress ANSI/
    # decoration/prompts when LGWRS_MACHINE is set); --transform reshapes JSON out.
    if getattr(args, "machine", False):
        os.environ["LGWRS_MACHINE"] = "1"
        os.environ["NO_COLOR"] = "1"
    transformer = None
    if getattr(args, "transform", None):
        transformer = TransformStdout(args.transform, getattr(args, "raw", False))
        sys.stdout = transformer
    try:
        return args.func(args)
    finally:
        if transformer:
            sys.stdout = transformer.original_stdout
            transformer.close()

if __name__ == "__main__":
    raise SystemExit(main())

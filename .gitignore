.DS_Store
__pycache__/
*.py[cod]

# Local crawl/research artifacts. The crawler writes reproducible run outputs here;
# keep code, specs, and curated docs tracked instead of committing crawl corpora/DBs.
.crwl/
vision/research/research-network/runs/

# jarvis akinator generated artifacts
research-map.mmd
runs/

# lgwks runtime output (project deploys, geo runs, embeddings). Never source of truth.
store/
.lgwks/

# Rust build products.
target/
axiom/rust/target/

# Governance runtime append-only logs (refusals, audits) — generated at runtime
governance/*.jsonl
governance/*.db
# LGWKS_NO_MODELS=1

# Claude Code local settings + worktrees — never source of truth
.claude/

# local model runtime venv (3.11 — torch/transformers for T-TORCH)
.venv-models/

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "lgwks.workflow.trigger.v1",
  "description": "Event-chain grammar (#121). A trigger is a pure predicate over the append-only #118 event log that, when matched, emits a #120 capability.action.v1 PROPOSAL — never a direct execution. `pattern` is an ordered sequence of EventMatchers over #118 events (filtering on source/kind/refs/subject); `required_evidence` are declarative predicates over the matched set; `confidence` carries a deterministic rule-based floor with the scorer model as an explicit open slot behind `basis`; `lowers_to` is the #120 action template the trigger emits. Replayable + non-executing by construction.",
  "type": "object",
  "required": ["schema", "trigger_id", "pattern", "confidence", "policy", "lowers_to"],
  "additionalProperties": false,
  "properties": {
    "schema": {"type": "string", "enum": ["lgwks.workflow.trigger.v1"]},
    "trigger_id": {"type": "string", "minLength": 1},
    "pattern": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {"type": "string", "enum": ["speech", "text", "browser", "repo", "terminal", "model", "workflow", "artifact"]},
          "kind": {"type": "string"},
          "subject_kind": {"type": "string"},
          "refs_contains": {"type": "array", "items": {"type": "string"}},
          "payload_truthy": {"type": "string"}
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {"type": {"type": "string", "enum": ["same_field", "payload_truthy", "within_ms"]}}
      }
    },
    "confidence": {
      "type": "object",
      "required": ["score", "basis"],
      "additionalProperties": true,
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "basis": {"type": "string", "description": "rule-based floor first; a scorer model is an open slot behind this field (spec §3.2)"}
      }
    },
    "preconditions": {"type": "array", "items": {"type": "object"}},
    "cooldown": {
      "type": "object",
      "additionalProperties": true,
      "properties": {"window": {"type": ["string", "number", "null"]}, "max_fires": {"type": "integer", "minimum": 1}}
    },
    "policy": {"type": "string", "enum": ["ask", "act"]},
    "lowers_to": {
      "type": "object",
      "required": ["verb"],
      "additionalProperties": true,
      "description": "the lgwks.capability.action.v1 proposal template this trigger emits",
      "properties": {
        "verb": {"type": "string"},
        "effect_class": {"type": "string"},
        "reversibility": {"type": "string"}
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lgwks.navmap.v1",
  "title": "lgwks navmap — relational + staleness module atlas",
  "description": "Generated by scripts/gen_navmap.py from source. Queryable map of the lgwks code surface so an agent navigates without re-grepping. Regenerate to refresh; never hand-edit.",
  "type": "object",
  "required": ["schema", "generated_from", "staleness_rules", "totals", "index", "modules"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "lgwks.navmap.v1"},
    "generated_from": {"type": "string"},
    "staleness_rules": {
      "type": "object",
      "description": "Exact textual definition of each staleness enum value.",
      "additionalProperties": {"type": "string"}
    },
    "totals": {
      "type": "object",
      "required": ["modules", "loc", "by_staleness", "by_integration"],
      "additionalProperties": true,
      "properties": {
        "modules": {"type": "integer"},
        "loc": {"type": "integer"},
        "by_staleness": {"type": "object", "additionalProperties": {"type": "integer"}},
        "by_integration": {"type": "object", "additionalProperties": {"type": "integer"}}
      }
    },
    "index": {
      "type": "object",
      "required": ["by_subsystem", "by_staleness", "by_issue", "by_packet"],
      "additionalProperties": false,
      "properties": {
        "by_subsystem": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
        "by_staleness": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
        "by_issue": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
        "by_packet": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}}
      }
    },
    "modules": {
      "type": "object",
      "description": "Keyed by module dotted-name (e.g. lgwks_vector, axiom.fabric, scripts.gen_navmap).",
      "additionalProperties": {
        "type": "object",
        "required": ["purpose", "loc", "deps", "used_by", "has_cli", "has_tests",
                     "subsystem", "staleness", "integration", "packet", "owning_issue",
                     "last_commit_days"],
        "additionalProperties": false,
        "properties": {
          "purpose": {"type": "string", "description": "First sentence of the module docstring."},
          "loc": {"type": "integer"},
          "deps": {"type": "array", "items": {"type": "string"}, "description": "Repo modules this one statically imports."},
          "used_by": {"type": "array", "items": {"type": "string"}, "description": "Callers: static importers UNION textual/dynamic referencers (incl. the dispatcher loaded by name)."},
          "has_cli": {"type": "boolean", "description": "Defines add_parser → a `lgwks` verb."},
          "has_tests": {"type": "boolean", "description": "A tests/test_<name>.py exists."},
          "subsystem": {"type": "string", "description": "End-state bucket."},
          "staleness": {"enum": ["active", "scaffolding", "staling", "orphan"]},
          "integration": {"enum": ["integrated", "cli_only", "unreferenced"]},
          "packet": {"type": ["string", "null"], "description": "Ingestion packet id (I1–I12) if applicable."},
          "owning_issue": {"type": ["string", "null"], "description": "Open canonical GitHub issue that owns this module, if any."},
          "last_commit_days": {"type": ["integer", "null"], "description": "Days since the file's most recent commit."}
        }
      }
    }
  }
}

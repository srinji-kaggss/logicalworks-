{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "lgwks.coscientist.v1",
  "description": "Schema for Co-Scientist research loops: Hypothesis -> Debate -> Rank -> Ground.",
  "type": "object",
  "required": ["run_id", "goal", "hypotheses", "verdict"],
  "properties": {
    "run_id": { "type": "string" },
    "goal": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["generating", "debating", "ranking", "evolving", "grounding", "finished"]
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "mechanism", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "mechanism": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "critiques": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "agent": { "type": "string" },
                "grade": { "type": "string" },
                "point": { "type": "string" }
              }
            }
          },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "verdict": { "type": "string" }
  }
}

%% =====================================================================
%% lgwks — THE ONE DATA MODEL: the State Fabric (whole pipeline)
%% Authority: spec/second-harness/ARCH-two-db-multitenant.md + lgwks_fabric_projection.
%%
%% THE 1 = ONE Source of Record (CausalTape) + MANY cid-keyed, tier-tagged
%% PROJECTIONS joined through one seam (StorageGate.ingest_artifact), read through
%% ONE access locus (lgwks_access.TenantStore, own ⊕ world). NOT one giant table —
%% one tape, many derived/rebuildable views. The relational SQL surface is a
%% COMPILED projection, never the ontology.
%%
%% Status (verified at HEAD): the fabric is largely built. lgwks_storage registers
%% 4 projections — VectorProjection(→vector_records), PostingProjection(BM25),
%% FactProjection(+global_facts), RelationalProjection(sources/documents/chunks/
%% vectors/facts/frontier), and GraphFabric(wraps entity_graph; #169 made it the
%% single graph store, replacing per-run graph.db).
%%
%% REMAINING WORK (what's still NOT one model):
%%   A) two stores still BYPASS the tape entirely (write own SQLite): lgwks_jarvis.*
%%      (per-run islands) and embed_port.system_graph (JSON blob).
%%   B) the graph projection is identity-UNALIGNED: entity_graph keys on node_id/hash,
%%      not cid/artifact_cid, and GraphFabric.apply() is inert pending Phase 2 (#165).
%% =====================================================================
flowchart LR

  subgraph BYPASS["A) STILL BYPASS THE TAPE — the real dupes to retire"]
    direction TB
    JV["lgwks_jarvis.*  — per-run DB islands<br/>runs·sources·documents·chunks·embeddings·nodes·edges<br/>id+run_id · vector_json TEXT · NO tier · re-embeds per run<br/>(NOT a consumer of the gate graph)"]
    SG["lgwks_embed_port.system_graph<br/>whole ingestion graph as one JSON blob"]
  end

  subgraph FABRIC["THE 1 — the State Fabric (built; gaps marked)"]
    direction TB
    TAPE["① SoR — CausalTape (lgwks_storage)<br/>append-only · per-tenant hash chain · content-idempotent<br/>every view below is derived + rebuildable by tape replay"]
    SEAM["② Seam — StorageGate.ingest_artifact (lgwks_fabric_projection)<br/>append → fan out to register_projection(…)"]
    subgraph VIEWS["③ Projections (registered)"]
      direction TB
      PV["VectorProjection → vector_records  ✓SEED<br/>cid PK · tier(space_id+tenant) · BLOB · modality · store-once"]
      PF["FactProjection + global_facts ✓<br/>fact_hash=cid · world accrual"]
      PP["PostingProjection ✓ (BM25 index)"]
      PR["RelationalProjection ✓<br/>sources/documents/chunks/vectors/frontier<br/>(COMPILED operational surface, not ontology)"]
      PG["GraphFabric → wraps entity_graph<br/>⚠ apply() INERT + keyed on node_id/hash, NOT cid<br/>→ Phase 2 #165: link nodes/edges to artifact_cid + tier"]
    end
    ACCESS["④ Access — lgwks_access.TenantStore (one door)<br/>read/query: tier='world' OR tier=:me · write: tenant only<br/>promote: lgwks_promote (gated · audited · MOVE not copy)<br/>§1-INV: cross-tenant read cryptographically refused"]
  end


%%{init: {"flowchart": {"htmlLabels": true, "curve": "basis"}} }%%
%% =====================================================================
%% lgwks — THE ONE DATA MODEL: the State Fabric (whole pipeline)
%% Authority: spec/second-harness/ARCH-two-db-multitenant.md ("one conceptual DB,
%%   world shared + tenant called in at query") + lgwks_fabric_projection
%%   ("the universal projection seam … a Projection is any derived view — the
%%    vector store, the posting list, THE ENTITY GRAPH, … rebuildable by tape replay").
%%
%% THE 1 = ONE Source of Record (CausalTape) + MANY cid-keyed, tier-tagged
%% PROJECTIONS joined through one seam, read through one access locus (TenantStore,
%% own ⊕ world). It is NOT "one giant table" — it is one tape, many derived views.
%%
%% THE DUPES = stores that each write their OWN SQLite file directly, bypassing the
%% tape. That bypass is the single thing they are all missing: no shared cid, no
%% tier/world, no rebuildability, no co-location. FIX = make each a registered
%% projection (write via StorageGate); DELETE its bespoke write path once it
%% replays from the tape.
%% =====================================================================
flowchart LR

  subgraph DUPES["TODAY — stores that BYPASS the tape (the semantic dupes)"]
    direction TB
    JV["lgwks_jarvis.*  (per-run DB islands)<br/>runs·sources·documents·chunks·embeddings·nodes·edges…<br/>id+run_id · vector_json TEXT · NO tier"]
    EG["lgwks_entity_graph  nodes·edges·chunks<br/>node_id/chunk_id · hash · NO tier"]
    SV["lgwks_storage.vectors  (projection-shaped but parallel)<br/>vector_json TEXT"]
    SG["lgwks_embed_port.system_graph<br/>whole graph as one JSON blob"]
  end

  subgraph MISS["THE ONE THING THEY ALL MISS"]
    direction TB
    X["NOT projections of the one tape →<br/>① no shared identity (content_sha256=hash=cid, 3 PK names)<br/>② no world ⊕ tenant tier<br/>③ no co-location (node→chunk→embed→fact split across files)<br/>④ not rebuildable from a SoR<br/>⑤ gaps: AST symbols · multimodal · cross-run accrual"]
  end

  subgraph FABRIC["THE 1 — the State Fabric"]
    direction TB
    TAPE["① SoR — CausalTape (lgwks_storage)<br/>append-only · per-tenant hash chain · content-idempotent<br/>EVERYTHING else is a derived, rebuildable view of this"]
    SEAM["② Projection seam — StorageGate.ingest_artifact<br/>(lgwks_fabric_projection)<br/>append → fan out to register_projection(…) views"]
    subgraph VIEWS["③ Projections — cid-keyed, tier-tagged, co-located"]
      direction TB
      PG["entity-graph view<br/>nodes + edges (cid PK, tier, kind, rel, weight)"]
      PV["vector view = vector_records (THE SEED)<br/>cid PK · tier(space_id+tenant) · BLOB · modality · store-once"]
      PC["chunk/document/source view (cid PK, tier)"]
      PF["fact view + global_facts (fact_hash=cid, world accrual)"]
      PP["token-posting view (BM25 index)"]
      PS["NEW: AST symbols view (cid PK, tier) — ingestion code_symbols parity"]
    end
    ACCESS["④ Access locus — lgwks_access.TenantStore (one door)<br/>read/query: tier='world' OR tier=:me  ·  write: tenant only<br/>promote: lgwks_promote (gated · audited · MOVE not copy)<br/>§1-INV: cross-tenant read cryptographically refused"]
  end

  JV --> X
  EG --> X
  SV --> X
  SG --> X
  X --> SEAM

  TAPE --> SEAM
  SEAM --> PG
  SEAM --> PV
  SEAM --> PC
  SEAM --> PF
  SEAM --> PP
  SEAM --> PS
  PG --> ACCESS
  PV --> ACCESS
  PC --> ACCESS
  PF --> ACCESS
  PP --> ACCESS
  PS --> ACCESS


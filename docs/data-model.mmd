  GF --> ACCESS
  SYM --> ACCESS
  ACCESS --> JARVIS
  ACCESS --> OTHER
  PROMOTE -. "tenant tier ⇒ world tier" .-> STORE

  subgraph DEL["✗ DELETE — JarvisDB parallel model (the semantic dupes)"]

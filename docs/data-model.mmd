    D3["run_id as identity/scope axis<br/>→ demote to a 'discovered_in_run' provenance edge"]
    D4["hashlib.sha256(...)[:16] in lgwks_jarvis<br/>= C-10 dup of lgwks_hashing / axiom.cid"]
  end
  JARVIS -. "replaces" .-> D1
  JARVIS -. "replaces" .-> D2
  JARVIS -. "replaces" .-> D3
  JARVIS -. "replaces" .-> D4


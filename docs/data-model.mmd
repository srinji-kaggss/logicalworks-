flowchart TB

  subgraph ID["① IDENTITY — the single dedup key"]
    CID["axiom/cid.compute_cid()<br/>blake2b-256 over canonical bytes<br/>verify/require at every store + read"]
    HASH["lgwks_hashing.content_id / digest<br/>(the C-10 anti-drift seam:<br/>no module re-derives hashlib.sha256)"]
    HASH --> CID
  end

  subgraph SOR["② SOURCE OF RECORD — append-only, content-idempotent"]
    TAPE["CausalTape (lgwks_storage)<br/>per-tenant hash chain:<br/>entry_hash · prev_hash · sequence<br/>relational tables are PROJECTIONS of this"]
  end

  subgraph GATE["③ INGEST — one write path"]
    SG["StorageGate.ingest_artifact<br/>(lgwks_fabric_projection)<br/>append → project → register global fact"]
  end

  subgraph STORE["④ ONE STORE — cid-keyed, tier-tagged (run_id is NOT the scope)"]
    NODES["nodes(cid PK, tier, kind, label, weight, meta)"]
    EDGES["edges(cid PK, tier, from_cid, to_cid, kind, weight, evidence)"]
    CHUNKS["chunks(cid PK, tier, text, content_sha256, word_count)"]
    VEC["vector_records(cid PK, space_id, tenant, modality,<br/>embedding BLOB, source_cid)<br/>embedding stored ONCE per cid per space"]
    GF["global_facts(fact_hash PK, seen_count, importance_score)"]
    SYM["symbols(cid PK, tier, file_cid, name, kind, line, signature)<br/>NEW — AST layer (gap vs ingestion code_symbols)"]
  end

  subgraph ACC["⑤ TIER RESOLUTION — own ⊕ world (one WHERE clause + WAL)"]
    ACCESS["lgwks_access.TenantStore / CapabilityPort<br/>scopes: tenant:rw + world:r<br/>read filter: tier='world' OR tier=:me<br/>cross-tenant read = cryptographically refused (§1-INV)"]
    PROMOTE["lgwks_promote.promote()<br/>ONLY tenant→world path · capability-gated<br/>· audited on cognition chain<br/>MOVE not copy: cid excludes tenant → a copy collides on PK"]
  end

  subgraph CONS["⑥ CONSUMERS"]
    JARVIS["lgwks_jarvis (research crawl)<br/>CONVERGES onto ④/⑤"]
    OTHER["query · score · refactor · daemon · review"]
  end

  CID --> TAPE
  TAPE --> SG
  SG --> NODES
  SG --> EDGES
  SG --> CHUNKS
  SG --> VEC
  SG --> GF
  SG --> SYM
  NODES --> ACCESS
  EDGES --> ACCESS
  CHUNKS --> ACCESS

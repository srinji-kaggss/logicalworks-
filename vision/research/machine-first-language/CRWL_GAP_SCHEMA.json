{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Logic Compiler Gap Crawl",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source",
    "retrieved_at",
    "research_axis",
    "claims",
    "gaps",
    "candidate_primitives",
    "anti_dredging_checks"
  ],
  "properties": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "title", "tier"],
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string" },
        "tier": { "type": "string", "enum": ["primary", "secondary", "tertiary", "unknown"] }
      }
    },
    "retrieved_at": {
      "type": "string",
      "description": "ISO 8601 retrieval timestamp if available."
    },
    "research_axis": {
      "type": "string",
      "enum": [
        "visual_node_ui",
        "process_modeling",
        "decision_modeling",
        "schema_validation",
        "state_machines",
        "build_graph",
        "agent_governance",
        "security_provenance",
        "unknown"
      ]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "evidence_span", "confidence"],
        "properties": {
          "claim": { "type": "string" },
          "evidence_span": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gap", "why_it_matters", "verify_to_close"],
        "properties": {
          "gap": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "verify_to_close": { "type": "string" }
        }
      }
    },
    "candidate_primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["primitive", "maps_to", "executable_anchor"],
        "properties": {
          "primitive": { "type": "string" },
          "maps_to": {
            "type": "string",
            "enum": ["node", "path", "block", "swimlane", "constraint", "transition", "effect", "evidence", "projection"]
          },
          "executable_anchor": { "type": "string" }
        }
      }
    },
    "anti_dredging_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "check"],
        "properties": {
          "risk": { "type": "string" },
          "check": { "type": "string" }
        }
      }
    }
  }
}

{"id": "impl-broker-framework", "label": "Broker — Swift actor bus", "level": 4, "band": "impl", "layer": "impl", "feature": "broker", "bin": "bin2", "priority": 2, "maturity": 0.85, "distance": 0.0, "status": "ships", "summary": "Swift actor (apps/mac/.../CanvasBroker/Broker.swift): the single authority for envelope stamping, capability enforcement, fan-out, telemetry tap.", "why": "[ride] Bin2 brokerage is the kernel test (T6 L4): one authority every signal passes through. Failure-if-absent: any signal that bypasses the broker makes Canvas a UI-with-extra-steps, not an OS. Leverage: extending this one chokepoint (not new call sites) is how governance becomes native.", "claims": [{"stmt": "27 Swift test files incl AbuseTests; most mature client surface", "url": "artifacts/canvas-architecture-recommendation.md#2"}], "refs": ["cv-broker", "bin2"], "val": 8, "origin": "manual", "manual": true, "by": "opus"}

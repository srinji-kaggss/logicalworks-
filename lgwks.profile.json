{
  "target": { "name": "logicalworks-", "root": ".", "ecosystem": "python" },
  "units": [
    { "unit": "core", "discover": { "type": "literal", "values": ["."] } }
  ],
  "bindings": [
    {
      "atom": "referential_truth",
      "unit": "core",
      "evidence": {
        "tool": "python3",
        "argv": ["-m", "py_compile", "lgwks"],
        "ok_when": "exit==0"
      }
    },
    {
      "atom": "testability_falsifiability",
      "unit": "core",
      "evidence": {
        "tool": "uv",
        "argv": ["run", "--python", "3.12", "--with", "pytest", "--with", "cryptography",
                 "--with", "pyyaml", "--with", "networkx", "python", "-m", "pytest",
                 "tests/", "axiom/tests/",
                 "--deselect", "tests/test_verify.py::TestMaturityScream", "-q"],
        "env": {"LGWKS_NO_MODELS": "1"},
        "ok_when": "exit==0"
      }
    },
    {
      "atom": "type_soundness",
      "unit": "core",
      "evidence": {
        "tool": "mypy",
        "argv": ["."],
        "ok_when": "exit==0"
      }
    },
    {
      "atom": "security_by_construction",
      "unit": "core",
      "evidence": {
        "tool": "python3",
        "argv": ["lgwks_bot_code_hacker.py", "--scan", ".", "--baseline", "findings_new.json"],
        "ok_when": "exit==0"
      }
    },
    {
      "atom": "specification_fidelity",
      "unit": "core",
      "evidence": {
        "tool": "python3",
        "argv": ["scripts/check_schema_registry.py"],
        "ok_when": "exit==0"
      }
    }
  ],
  "gate_concept": "lgwks_floor",
  "_comment": "envelope: users:100 (a multi-tenant capacity claim) was REPLACED 2026-06-22 (#311) by chunks_per_sec — lgwks is local-first / single-operator (repo CLAUDE.md), so a concurrent-users axis had no real failure surface and no measurable harness. Both remaining dimensions are now genuinely measured by model-free soak harnesses (claim = evidence).",
  "envelope": {
    "target": { "calls_per_sec": 10, "chunks_per_sec": 50 },
    "margin": 1.2
  },
  "simulate": [
    {
      "name": "vecmath_l2_norm_postcondition",
      "atom": "postcondition_correctness",
      "sensors": [
        { "name": "n", "values": [0, 1, 2], "range": [0, 2], "step": 1, "probe_outside": true }
      ],
      "reference": {
        "source_ref": "Euclidean L2 norm identity: ||[3n,4n]|| = sqrt((3n)^2+(4n)^2) = 5*|n| (3-4-5 Pythagorean). Hand-reconstructable with a calculator, no internet.",
        "tolerance": 0.0001,
        "data": [
          { "when": { "n": -1 }, "expect": 5 },
          { "when": { "n": 0 }, "expect": 0 },
          { "when": { "n": 1 }, "expect": 5 },
          { "when": { "n": 2 }, "expect": 10 },
          { "when": { "n": 3 }, "expect": 15 }
        ]
      },
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/simulate_vecmath.py", "l2_norm_3n4n"]
      }
    },
    {
      "name": "vecmath_dot_boundary",
      "atom": "boundary_completeness",
      "sensors": [
        { "name": "n", "values": [0, 1, 2], "range": [0, 2], "step": 1, "probe_outside": true }
      ],
      "reference": {
        "source_ref": "Dot-product identity: <[n,n],[n,n]> = n*n + n*n = 2*n^2. Drives the declared range edges (0,2) AND the off-nominal points just outside (-1,3) to assert boundary completeness.",
        "tolerance": 0.0001,
        "data": [
          { "when": { "n": -1 }, "expect": 2 },
          { "when": { "n": 0 }, "expect": 0 },
          { "when": { "n": 1 }, "expect": 2 },
          { "when": { "n": 2 }, "expect": 8 },
          { "when": { "n": 3 }, "expect": 18 }
        ]
      },
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/simulate_vecmath.py", "dot_nn"]
      }
    },
    {
      "name": "vecmath_cosine_precondition",
      "atom": "precondition_correctness",
      "sensors": [
        { "name": "n", "values": [0, 1, 2], "range": [0, 2], "step": 1, "probe_outside": true }
      ],
      "reference": {
        "source_ref": "cos([n,0],[0,n]) = 0: the two axis vectors are orthogonal for any n, and the precondition for the n=0 zero vector is handled gracefully (returns 0, not NaN/raise). Verified against lgwks_vecmath.cosine on 2026-06-22.",
        "tolerance": 0.0001,
        "data": [
          { "when": { "n": -1 }, "expect": 0 },
          { "when": { "n": 0 }, "expect": 0 },
          { "when": { "n": 1 }, "expect": 0 },
          { "when": { "n": 2 }, "expect": 0 },
          { "when": { "n": 3 }, "expect": 0 }
        ]
      },
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/simulate_vecmath.py", "cosine_orth"]
      }
    },
    {
      "name": "vecmath_cosine_falsifiable",
      "atom": "testability_falsifiability",
      "sensors": [
        { "name": "n", "values": [0, 1, 2], "range": [0, 2], "step": 1, "probe_outside": true }
      ],
      "reference": {
        "source_ref": "cos([n,0],[2n,0]) = 1 for n != 0 (parallel, same direction) with a discontinuity to 0 at the n=0 zero vector. A falsifiable oracle with a real boundary: a regression that mishandled the zero vector or sign would break exactly at n=0.",
        "tolerance": 0.0001,
        "data": [
          { "when": { "n": -1 }, "expect": 1 },
          { "when": { "n": 0 }, "expect": 0 },
          { "when": { "n": 1 }, "expect": 1 },
          { "when": { "n": 2 }, "expect": 1 },
          { "when": { "n": 3 }, "expect": 1 }
        ]
      },
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/simulate_vecmath.py", "cosine_parallel"]
      }
    }
  ],
  "sim": [
    {
      "name": "crdt_gset_convergence",
      "atom": "concurrency_correctness",
      "actors": [
        { "id": "A", "steps": ["add:x", "add:y"] },
        { "id": "B", "steps": ["add:z"] },
        { "id": "C", "steps": ["add:w"] }
      ],
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/sim_crdt_gset.py"]
      }
    }
  ],
  "soak": [
    {
      "dimension": "calls_per_sec",
      "evidence": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/soak_calls_per_sec.py"]
      }
    },
    {
      "dimension": "chunks_per_sec",
      "evidence": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/soak_chunks_per_sec.py"]
      }
    }
  ],
  "latency": [
    {
      "name": "content_id_latency",
      "atom": "algorithmic_efficiency",
      "samples": 5,
      "budget": {
        "max_ms": 100,
        "source_ref": "Derived from envelope.target.calls_per_sec=10: to sustain 10 calls/sec single-threaded one call must complete within 1000ms/10 = 100ms. Not fitted to the measurement (which is ~0.0006ms) — it is the cited ceiling the throughput target implies (docs/10 §10.3: a threshold must be cited, not invented)."
      },
      "harness": {
        "tool": "python3",
        "needs": ["python3"],
        "env": { "LGWKS_NO_MODELS": "1" },
        "argv": ["scripts/ci/harness/latency_core.py"]
      }
    }
  ]
}
